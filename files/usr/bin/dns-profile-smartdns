#!/bin/sh

set -eu

SMARTDNS_PORT="${SMARTDNS_PORT:-6053}"

if ! uci -q show smartdns | grep -q "=smartdns"; then
	uci add smartdns smartdns >/dev/null
fi

if ! uci -q show mosdns.config >/dev/null 2>&1; then
	uci set mosdns.config='mosdns'
fi

# 切回 SmartDNS 时，同时把 LAN 侧 IPv6 DNS 通告拉回本机，防止客户端绕过当前 DNS 栈。
uci -q set dhcp.lan.ra_dns='1'
uci -q set dhcp.lan.dns_service='1'
uci -q delete dhcp.lan.dns

uci -q delete dhcp.@dnsmasq[0].server
uci -q add_list dhcp.@dnsmasq[0].server="127.0.0.1#${SMARTDNS_PORT}"
uci -q add_list dhcp.@dnsmasq[0].server="::1#${SMARTDNS_PORT}"
uci -q set dhcp.@dnsmasq[0].cachesize='0'
uci -q set dhcp.@dnsmasq[0].noresolv='1'

# 切换到 SmartDNS 时同步恢复首启调优，避免切换后只改端口而丢掉缓存和预取参数。
uci -q set smartdns.@smartdns[0].enabled='1'
uci -q set smartdns.@smartdns[0].port="${SMARTDNS_PORT}"
uci -q set smartdns.@smartdns[0].tcp_server='1'
uci -q set smartdns.@smartdns[0].prefetch_domain='1'
uci -q set smartdns.@smartdns[0].serve_expired='1'
uci -q set smartdns.@smartdns[0].cache_size='8192'
uci -q set smartdns.@smartdns[0].cache_persist='1'
uci -q set smartdns.@smartdns[0].dualstack_ip_selection='0'
uci -q set smartdns.@smartdns[0].force_aaaa_soa='0'
uci -q set smartdns.@smartdns[0].speed_check_mode='tcp:443,tcp:80'
uci -q set smartdns.@smartdns[0].rr_ttl_min='600'
uci -q set smartdns.@smartdns[0].rr_ttl_max='3600'
uci -q set smartdns.@smartdns[0].rr_ttl_reply_max='60'
uci -q set smartdns.@smartdns[0].response_mode='first-ping'
uci -q set mosdns.config.enabled='0'
uci -q set mosdns.config.redirect='0'
uci -q set mosdns.config.local_dns_redirect='0'

uci -q commit dhcp
uci -q commit smartdns
uci -q commit mosdns

/etc/init.d/mosdns disable >/dev/null 2>&1 || true
/etc/init.d/mosdns stop >/dev/null 2>&1 || true
/etc/init.d/smartdns enable >/dev/null 2>&1 || true
/etc/init.d/smartdns restart >/dev/null 2>&1 || true
/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true

echo "Switched to SmartDNS profile on port ${SMARTDNS_PORT}"

#!/bin/sh

set -eu

MOSDNS_PORT="$(uci -q get mosdns.config.listen_port || true)"
[ -n "${MOSDNS_PORT}" ] || MOSDNS_PORT="$(uci -q get mosdns.config.port || true)"
[ -n "${MOSDNS_PORT}" ] || MOSDNS_PORT="$(uci -q get mosdns.config.dns_port || true)"
[ -n "${MOSDNS_PORT}" ] || MOSDNS_PORT="5335"

if ! uci -q show smartdns | grep -q "=smartdns"; then
	uci add smartdns smartdns >/dev/null
fi

if ! uci -q show mosdns.config >/dev/null 2>&1; then
	uci set mosdns.config='mosdns'
fi

# 切回 MosDNS 时，同步恢复 LAN 侧 IPv6 本机 DNS 通告，避免 IPv6 客户端直接走上游 DNS。
uci -q set dhcp.lan.ra_dns='1'
uci -q set dhcp.lan.dns_service='1'
uci -q delete dhcp.lan.dns

uci -q delete dhcp.@dnsmasq[0].server
uci -q add_list dhcp.@dnsmasq[0].server="127.0.0.1#${MOSDNS_PORT}"
uci -q add_list dhcp.@dnsmasq[0].server="::1#${MOSDNS_PORT}"
uci -q set dhcp.@dnsmasq[0].cachesize='0'
uci -q set dhcp.@dnsmasq[0].noresolv='1'

uci -q set smartdns.@smartdns[0].enabled='0'
uci -q set mosdns.config.enabled='1'
uci -q set mosdns.config.redirect='1'
# 切换到 MosDNS 时同步恢复缓存参数，避免高频域名查询全部回源。
uci -q set mosdns.config.cache='1'
uci -q set mosdns.config.cache_size='4096'
uci -q set mosdns.config.lazy_cache_ttl='86400'
uci -q set mosdns.config.adblock='0'
uci -q set mosdns.config.custom_stream_media_dns='0'

uci -q commit dhcp
uci -q commit smartdns
uci -q commit mosdns

/etc/init.d/smartdns disable >/dev/null 2>&1 || true
/etc/init.d/smartdns stop >/dev/null 2>&1 || true
/etc/init.d/mosdns enable >/dev/null 2>&1 || true
/etc/init.d/mosdns restart >/dev/null 2>&1 || true
/etc/init.d/dnsmasq restart >/dev/null 2>&1 || true

echo "Switched to MosDNS profile on port ${MOSDNS_PORT}"
